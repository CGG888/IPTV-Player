<Window x:Class="LibmpvIptvClient.M3uListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="M3U 管理" Width="720" Height="420" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}">
  <DockPanel Margin="12">
    <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,8">
      <Button Content="编辑" Width="80" Margin="0,0,8,0" Click="BtnEdit_Click" Style="{StaticResource ChipButton}"/>
      <Button Content="删除" Width="80" Margin="0,0,8,0" Click="BtnDelete_Click" Style="{StaticResource ChipButton}"/>
      <Button Content="全选" Width="72" Margin="12,0,4,0" Click="BtnSelectAll_Click" Style="{StaticResource ChipButton}"/>
      <Button Content="反选" Width="72" Margin="4,0,8,0" Click="BtnInvert_Click" Style="{StaticResource ChipButton}"/>
    </StackPanel>
    <DataGrid x:Name="Grid" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column" RowHeaderWidth="0"
              Background="{DynamicResource CardBackgroundBrush}" Foreground="{DynamicResource TextPrimaryBrush}" GridLinesVisibility="Horizontal">
      <DataGrid.Columns>
        <DataGridCheckBoxColumn Header="" Binding="{Binding IsSelected}" Width="48"/>
        <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="2*"/>
        <DataGridTextColumn Header="地址" Binding="{Binding Url}" Width="4*"/>
      </DataGrid.Columns>
    </DataGrid>
  </DockPanel>
</Window>
