{
  "backend": {
    "iptvChecker": {
      "baseUrl": "http://localhost:8080",
      "token": "",
      "mode": "internal",
      "endpoints": {
        "m3u": "/api/export/m3u",
        "json": "/api/export/json",
        "epg": "/api/epg",
        "logo": "/api/logo"
      },
      "params": {
        "withCatchup": "true",
        "withLogos": "true"
      },
      "catchup": {
        "format": "ku9"
      }
    }
  },
  "playback": {
    "lowLatency": false,
    "rtspTransport": "auto"
  },
  "fcc": {
    "enabled": true,
    "mode": "hybrid",
    "parallelMax": 2,
    "keyframeTimeoutMs": 600,
    "switchGuardMs": 300,
    "multicastJoinTimeoutMs": 800
  }
}
