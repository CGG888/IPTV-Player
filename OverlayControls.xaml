<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:local="clr-namespace:LibmpvIptvClient"
        x:Class="LibmpvIptvClient.OverlayControls"
        Title="OverlayControls"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Width="900" Height="80"
        ShowActivated="False"
        PreviewMouseWheel="OnPreviewMouseWheel">
    <Window.Resources>
      <SolidColorBrush x:Key="OverlayBg" Color="#CC000000"/>
      <SolidColorBrush x:Key="OverlayFg" Color="#EEEEEE"/>
      <SolidColorBrush x:Key="AccentBrush" Color="#FF35C759"/>
      <SolidColorBrush x:Key="SliderInactiveBrush" Color="#333"/>
      <local:RangeToWidthConverter x:Key="RangeToWidth"/>

      <!-- Playback Status Indicator Style -->
      <Style x:Key="StatusIndicatorStyle" TargetType="Border">
        <Setter Property="Background" Value="#80000000"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="IsHitTestVisible" Value="False"/>
      </Style>

      <Style x:Key="OverlayTagChip" TargetType="Border">
        <Setter Property="Background" Value="#202020"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="BorderBrush" Value="#333"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="Margin" Value="6,0,0,0"/>
      </Style>

      <!-- 基础按钮样式 -->
      <Style x:Key="OverlayButtonBase" TargetType="{x:Type ButtonBase}">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width" Value="30"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Margin" Value="8,0,0,0"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ButtonBase}">
                    <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#22FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#1AFFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
      </Style>
      
      <Style x:Key="OverlayIconButton" TargetType="Button" BasedOn="{StaticResource OverlayButtonBase}"/>
      
      <Style x:Key="OverlayToggle" TargetType="ToggleButton" BasedOn="{StaticResource OverlayButtonBase}">
        <Setter Property="Width" Value="Auto"/>
        <Setter Property="Padding" Value="8,0"/>
        <Style.Triggers>
          <Trigger Property="IsChecked" Value="True">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
          </Trigger>
        </Style.Triggers>
      </Style>

      <!-- 进度条样式 -->
      <Style x:Key="ThickSlider" TargetType="Slider">
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="Slider">
              <Grid Height="20" Background="Transparent">
                <Border Height="2" CornerRadius="1" Background="{StaticResource SliderInactiveBrush}" VerticalAlignment="Center"/>
                <Border Height="8" CornerRadius="4" Background="{StaticResource AccentBrush}" VerticalAlignment="Center" HorizontalAlignment="Left">
                  <Border.Width>
                    <MultiBinding Converter="{StaticResource RangeToWidth}">
                      <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="ActualWidth"/>
                      <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Value"/>
                      <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Minimum"/>
                      <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Maximum"/>
                    </MultiBinding>
                  </Border.Width>
                </Border>
                <Track x:Name="PART_Track">
                  <Track.DecreaseRepeatButton>
                    <!-- 隐藏原生填充，避免与自定义进度条重复 -->
                    <RepeatButton Command="Slider.DecreaseLarge" Background="#00FFFFFF">
                      <RepeatButton.Template>
                        <ControlTemplate TargetType="RepeatButton">
                          <Border Height="0" Background="#00FFFFFF"/>
                        </ControlTemplate>
                      </RepeatButton.Template>
                    </RepeatButton>
                  </Track.DecreaseRepeatButton>
                  <Track.Thumb>
                    <Thumb Width="14" Height="14" VerticalAlignment="Center">
                      <Thumb.Template>
                        <ControlTemplate TargetType="Thumb">
                            <Grid>
                                <Ellipse Fill="White" Stroke="#101010" StrokeThickness="1">
                                    <Ellipse.Effect>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="4" Opacity="0.5"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                            </Grid>
                        </ControlTemplate>
                      </Thumb.Template>
                    </Thumb>
                  </Track.Thumb>
                  <Track.IncreaseRepeatButton>
                    <RepeatButton Command="Slider.IncreaseLarge" Background="#00FFFFFF">
                      <RepeatButton.Template>
                        <ControlTemplate TargetType="RepeatButton">
                          <Border Height="8" CornerRadius="4" Background="#00FFFFFF" VerticalAlignment="Center"/>
                        </ControlTemplate>
                      </RepeatButton.Template>
                    </RepeatButton>
                  </Track.IncreaseRepeatButton>
                </Track>
              </Grid>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
    </Window.Resources>

    <Border Background="{StaticResource OverlayBg}" CornerRadius="8" BorderBrush="#333" BorderThickness="1">
      <Grid Margin="12,0">
        <!-- Status Indicator (Moved to separate Canvas/Popup if needed, but here it's part of controls) -->
        <!-- Actually, user wants it in the bottom-left of video area. OverlayControls is bottom bar. -->
        <!-- We can add it to the left side of the controls or use a separate window. -->
        <!-- Given the user request, it's better to add it to this window but position it absolutely? -->
        <!-- No, OverlayControls window is only the bottom bar. We need a new window or modify this one to cover full screen? -->
        <!-- Wait, the user said "Red marked area" which implies bottom-left of SCREEN/VIDEO. -->
        <!-- OverlayControls is usually at the bottom center. -->
        <!-- Let's add it to the left of the play button. -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- 进度条 -->
                <RowDefinition Height="*"/>    <!-- 按钮 -->
            </Grid.RowDefinitions>


            <!-- 进度条行（右侧追加音量滑块） -->
            <Grid Grid.Row="0" Margin="0,0,0,0" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>
            <Slider Grid.Column="0" x:Name="SliderSeek" Height="20" Style="{StaticResource UnifiedThickSlider}" 
                    Minimum="0" Maximum="100" 
                    ValueChanged="SliderSeek_ValueChanged" 
                    PreviewMouseDown="SliderSeek_PreviewMouseDown"
                    PreviewMouseUp="SliderSeek_PreviewMouseUp"
                    PreviewMouseMove="SliderSeek_MouseMove"
                    MouseLeave="SliderSeek_MouseLeave"/>
            <Grid Grid.Column="1" Margin="12,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="BtnMute" Grid.Column="0" Style="{StaticResource OverlayIconButton}" ToolTip="静音" Click="BtnMute_Click" Width="32" Height="20" Margin="0,0,6,0">
                    <ui:SymbolIcon x:Name="IconMute" Symbol="Volume" />
                </Button>
                <Slider Grid.Column="1" x:Name="SliderVolume" Minimum="0" Maximum="100" 
                        ValueChanged="SliderVolume_ValueChanged" Style="{StaticResource UnifiedThickSlider}" VerticalAlignment="Center"/>
            </Grid>
        </Grid>

        <!-- 按钮行 -->
        <Grid Grid.Row="1" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/> <!-- 左 -->
                <ColumnDefinition Width="*"/>    <!-- 中 -->
                <ColumnDefinition Width="Auto"/> <!-- 右 -->
            </Grid.ColumnDefinitions>

            <!-- 左侧：播放控制 -->
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <!-- Status Indicator (Left of controls) -->
                <Border x:Name="StatusIndicatorInner" Style="{StaticResource StatusIndicatorStyle}" VerticalAlignment="Center" Margin="0,0,16,0" Visibility="Collapsed">
                    <TextBlock x:Name="TxtStatusInner" Text="直播" Foreground="White" FontSize="14" FontWeight="Bold"/>
                </Border>

                <Button x:Name="BtnPlayPause" Style="{StaticResource OverlayIconButton}" Click="BtnPlayPause_Click" FontSize="18">
                    <ui:SymbolIcon x:Name="IconPlayPause" Symbol="Play"/>
                </Button>
                <Button x:Name="BtnStop" Style="{StaticResource OverlayIconButton}" Click="BtnStop_Click" FontSize="18">
                    <ui:SymbolIcon Symbol="Stop"/>
                </Button>
                <Button x:Name="BtnRew" Style="{StaticResource OverlayIconButton}" Click="BtnRew_Click">
                    <ui:SymbolIcon Symbol="Previous"/>
                </Button>
                <Button x:Name="BtnFwd" Style="{StaticResource OverlayIconButton}" Click="BtnFwd_Click">
                    <ui:SymbolIcon Symbol="Next"/>
                </Button>
                
                <!-- 时间信息 -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <TextBlock x:Name="LblElapsed" Text="00:00" Foreground="#AAA" FontSize="12"/>
                    <TextBlock Text=" / " Foreground="#666" FontSize="12"/>
                    <TextBlock x:Name="LblDuration" Text="00:00" Foreground="#AAA" FontSize="12"/>
                </StackPanel>
                <WrapPanel x:Name="TagPanelOverlay" VerticalAlignment="Center" Margin="12,0,0,0"/>
            </StackPanel>

            <!-- 中间：状态信息（与窗口保持一致，隐藏文本） -->
            <TextBlock x:Name="LblInfo" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#DDD" FontSize="12" TextTrimming="CharacterEllipsis" Visibility="Collapsed"/>

            <!-- 右侧：工具 -->
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <!-- FCC/UDP removed from here -->
                <Button x:Name="BtnSources" Style="{StaticResource OverlayIconButton}" ToolTip="切换源" Click="BtnSourceMenu_Click">
                    <ui:SymbolIcon Symbol="Shuffle"/>
                </Button>
                <Button x:Name="BtnRatio" Style="{StaticResource OverlayIconButton}" ToolTip="画面比例" Click="BtnRatio_Click">
                    <ui:SymbolIcon Symbol="Crop"/>
                </Button>
                <ToggleButton x:Name="CbTimeshift" Style="{StaticResource OverlayToggle}" ToolTip="时移">
                    <ui:SymbolIcon Symbol="Clock"/>
                </ToggleButton>
                
                <ToggleButton x:Name="CbEpg" Style="{StaticResource OverlayToggle}" ToolTip="节目指南" Click="CbEpg_Checked">
                    <ui:SymbolIcon Symbol="Calendar"/>
                </ToggleButton>

                <ToggleButton x:Name="CbDrawer" Style="{StaticResource OverlayToggle}" ToolTip="折叠频道表" Click="CbDrawer_Checked">
                    <ui:SymbolIcon Symbol="List"/>
                </ToggleButton>
            </StackPanel>
        </Grid>
      </Grid>
    </Grid>
  </Border>
</Window>
