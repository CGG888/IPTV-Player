<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:controls="clr-namespace:LibmpvIptvClient.Controls"
        x:Class="LibmpvIptvClient.SettingsWindow"
        Title="{DynamicResource UI_SettingsTitle}" Width="800" Height="600" WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" Icon="pack://application:,,,/srcbox.ico"
        Background="{DynamicResource AppBackgroundBrush}" Foreground="{DynamicResource TextPrimaryBrush}">
  <WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="40" GlassFrameThickness="0" CornerRadius="8" ResizeBorderThickness="0" UseAeroCaptionButtons="False"/>
  </WindowChrome.WindowChrome>
  <Window.Resources>
      <Style x:Key="ChipButton" TargetType="{x:Type Button}">
          <Setter Property="Background" Value="{DynamicResource ChipButtonBackgroundBrush}"/>
          <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
          <Setter Property="BorderBrush" Value="{DynamicResource ChipButtonBorderBrush}"/>
          <Setter Property="BorderThickness" Value="1"/>
          <Setter Property="Padding" Value="12,6"/>
          <Setter Property="MinWidth" Value="82"/>
          <Setter Property="Height" Value="30"/>
          <Setter Property="Cursor" Value="Hand"/>
          <Setter Property="Template">
              <Setter.Value>
                  <ControlTemplate TargetType="{x:Type Button}">
                      <Border x:Name="bd" CornerRadius="6" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                          <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                      </Border>
                      <ControlTemplate.Triggers>
                          <Trigger Property="IsMouseOver" Value="True">
                              <Setter TargetName="bd" Property="Background" Value="{DynamicResource ChipButtonHoverBrush}"/>
                              <Setter Property="BorderBrush" Value="{DynamicResource ChipButtonBorderBrush}"/>
                          </Trigger>
                          <Trigger Property="IsPressed" Value="True">
                              <Setter TargetName="bd" Property="Background" Value="{DynamicResource ChipButtonPressedBrush}"/>
                          </Trigger>
                          <Trigger Property="IsEnabled" Value="False">
                              <Setter Property="Opacity" Value="0.6"/>
                          </Trigger>
                      </ControlTemplate.Triggers>
                  </ControlTemplate>
              </Setter.Value>
          </Setter>
      </Style>
      <Style TargetType="TextBox">
          <Setter Property="Background" Value="{DynamicResource ChipButtonBackgroundBrush}"/>
          <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
          <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushCommon}"/>
          <Setter Property="Padding" Value="4,2"/>
          <Setter Property="VerticalContentAlignment" Value="Center"/>
      </Style>
      <Style TargetType="CheckBox">
          <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
          <Setter Property="VerticalContentAlignment" Value="Center"/>
      </Style>
      <Style TargetType="Button">
          <Setter Property="Background" Value="{DynamicResource ChipButtonBackgroundBrush}"/>
          <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
          <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushCommon}"/>
          <Setter Property="Padding" Value="8,4"/>
          <Setter Property="Template">
              <Setter.Value>
                  <ControlTemplate TargetType="Button">
                      <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="4">
                          <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      </Border>
                      <ControlTemplate.Triggers>
                          <Trigger Property="IsMouseOver" Value="True">
                              <Setter Property="Background" Value="{DynamicResource ChipButtonHoverBrush}"/>
                          </Trigger>
                          <Trigger Property="IsPressed" Value="True">
                              <Setter Property="Background" Value="{DynamicResource ChipButtonPressedBrush}"/>
                          </Trigger>
                      </ControlTemplate.Triggers>
                  </ControlTemplate>
              </Setter.Value>
          </Setter>
      </Style>
      <Style x:Key="TitleBarButton" TargetType="ButtonBase">
          <Setter Property="Background" Value="Transparent"/>
          <Setter Property="BorderThickness" Value="0"/>
          <Setter Property="Width" Value="46"/>
          <Setter Property="Height" Value="32"/>
          <Setter Property="VerticalAlignment" Value="Center"/>
          <Setter Property="Template">
              <Setter.Value>
                  <ControlTemplate TargetType="ButtonBase">
                      <Border x:Name="bd" Background="{TemplateBinding Background}">
                          <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      </Border>
                      <ControlTemplate.Triggers>
                          <Trigger Property="IsMouseOver" Value="True">
                              <Setter TargetName="bd" Property="Background" Value="#33FFFFFF"/>
                          </Trigger>
                          <Trigger Property="IsPressed" Value="True">
                              <Setter TargetName="bd" Property="Background" Value="#22000000"/>
                          </Trigger>
                      </ControlTemplate.Triggers>
                  </ControlTemplate>
              </Setter.Value>
          </Setter>
      </Style>
  </Window.Resources>
  <Border Background="{DynamicResource AppBackgroundBrush}" CornerRadius="8" BorderBrush="{DynamicResource BorderBrushCommon}" BorderThickness="1">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="40"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <Border Grid.Row="0" Background="{DynamicResource TitleBarBrush}" BorderBrush="{DynamicResource BorderBrushCommon}" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <Grid Margin="12,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Image Source="/srcbox.png" Width="18" Height="18" Margin="0,0,8,0"/>
            <TextBlock Text="{DynamicResource UI_SettingsTitle}" Foreground="#EEE" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
          </StackPanel>
          <Button Grid.Column="2" Click="BtnCloseTitle_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True">
            <Button.Style>
              <Style TargetType="ButtonBase" BasedOn="{StaticResource TitleBarButton}">
                <Style.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                  </Trigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
            <Path Data="M4.5,4.5 L11.5,11.5 M11.5,4.5 L4.5,11.5" Stroke="#DDD" StrokeThickness="1" Stretch="None" VerticalAlignment="Center" HorizontalAlignment="Center"/>
          </Button>
        </Grid>
      </Border>

      <Grid Grid.Row="1" Margin="16,12,16,16">
        <Grid.RowDefinitions>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- 抽屉式分类导航（左侧） + 内容（右侧） -->
        <TabControl Grid.Row="0" x:Name="NavTabs" TabStripPlacement="Left" Background="{DynamicResource CardBackgroundBrush}" BorderThickness="0" Foreground="{DynamicResource TextPrimaryBrush}">
          <TabControl.Resources>
            <Style TargetType="{x:Type TabItem}">
              <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
              <Setter Property="Background" Value="{DynamicResource ChipButtonBackgroundBrush}"/>
              <Setter Property="Padding" Value="14,10"/>
              <Setter Property="Margin" Value="0,4,6,4"/>
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="{x:Type TabItem}">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{DynamicResource BorderBrushCommon}" BorderThickness="1" CornerRadius="6" Padding="{TemplateBinding Padding}">
                      <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                      <Trigger Property="IsSelected" Value="True">
                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ChipButtonHoverBrush}"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                      </Trigger>
                      <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ChipButtonHoverBrush}"/>
                      </Trigger>
                      <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Opacity" Value="0.6"/>
                      </Trigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </TabControl.Resources>

          <!-- 界面（语言与外观） -->
          <TabItem Header="{DynamicResource UI_TabInterface}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
              <Grid Margin="16,8,16,8">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource UI_Language}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <ComboBox x:Name="CbLanguage" Grid.Row="0" Grid.Column="1" Height="30" Width="220" SelectedIndex="0" Margin="0,0,0,0">
                  <ComboBoxItem Content="{DynamicResource UI_FollowSystem}" Tag=""/>
                  <ComboBoxItem Content="{DynamicResource UI_ChineseSimplified}" Tag="zh-CN"/>
                  <ComboBoxItem Content="{DynamicResource UI_ChineseTraditional}" Tag="zh-TW"/>
                  <ComboBoxItem Content="{DynamicResource UI_English}" Tag="en-US"/>
                  <ComboBoxItem Content="{DynamicResource UI_Russian}" Tag="ru-RU"/>
                </ComboBox>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource UI_Appearance}" VerticalAlignment="Center" Margin="0,12,16,0"/>
                <ComboBox x:Name="CbTheme" Grid.Row="1" Grid.Column="1" Height="30" Width="220" Margin="0,12,0,0">
                  <ComboBoxItem Content="{DynamicResource UI_FollowSystem}" Tag="System"/>
                  <ComboBoxItem Content="{DynamicResource UI_Light}" Tag="Light"/>
                  <ComboBoxItem Content="{DynamicResource UI_Dark}" Tag="Dark"/>
                </ComboBox>
                <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="{DynamicResource UI_LangThemeNote}" Foreground="#888" Margin="0,12,0,0"/>
              </Grid>
            </ScrollViewer>
          </TabItem>

          <!-- 播放 -->
          <TabItem Header="{DynamicResource UI_TabPlayback}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
              <Grid Margin="16,8,16,8">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <!-- New options -->
                  <RowDefinition Height="Auto"/><!-- 6: Adaptive toggle -->
                  <RowDefinition Height="Auto"/><!-- 7: Adaptive hint -->
                  <RowDefinition Height="Auto"/><!-- 8: HLS live edge -->
                  <RowDefinition Height="Auto"/><!-- 9: HLS readahead -->
                  <RowDefinition Height="Auto"/><!-- 10: HLS hint -->
                  <RowDefinition Height="Auto"/><!-- 11: Alang -->
                  <RowDefinition Height="Auto"/><!-- 12: Slang -->
                  <RowDefinition Height="Auto"/><!-- 13: Lang hint -->
                  <RowDefinition Height="Auto"/><!-- 14: mpv timeout -->
                  <RowDefinition Height="Auto"/><!-- 15: Timeout hint -->
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <CheckBox x:Name="CbHwdec" Grid.Row="0" Grid.ColumnSpan="2" Content="{DynamicResource UI_Playback_EnableHwdec}" Margin="0,0,0,16"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource UI_Playback_CacheSecs}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <TextBox x:Name="TbCacheSecs" Grid.Row="1" Grid.Column="1" Height="30"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource UI_Playback_DemuxerMaxBytes}" VerticalAlignment="Center" Margin="0,12,16,0"/>
                <TextBox x:Name="TbMaxBytes" Grid.Row="2" Grid.Column="1" Height="30" Margin="0,12,0,0"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource UI_Playback_DemuxerMaxBackBytes}" VerticalAlignment="Center" Margin="0,12,16,0"/>
                <TextBox x:Name="TbMaxBackBytes" Grid.Row="3" Grid.Column="1" Height="30" Margin="0,12,0,0"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource UI_Playback_FCCPrefetch}" VerticalAlignment="Center" Margin="0,12,16,0"/>
                <TextBox x:Name="TbFccPrefetch" Grid.Row="4" Grid.Column="1" Height="30" Margin="0,12,0,0"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="{DynamicResource UI_Playback_TimeoutSec}" VerticalAlignment="Center" Margin="0,12,16,0"/>
                <TextBox x:Name="TbSourceTimeout" Grid.Row="5" Grid.Column="1" Height="30" Margin="0,12,0,0"/>

                <!-- Adaptive toggle -->
                <CheckBox x:Name="CbAdaptive" Grid.Row="6" Grid.ColumnSpan="2" Content="{DynamicResource UI_Playback_EnableAdaptive}" Margin="0,12,0,0"/>
                <TextBlock Grid.Row="7" Grid.ColumnSpan="2" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,2,0,0"
                           Text="{DynamicResource UI_Playback_AdaptiveHint}" TextWrapping="Wrap"/>
                
                <!-- HLS options -->
                <CheckBox x:Name="CbHlsStart" Grid.Row="8" Grid.ColumnSpan="2" Content="{DynamicResource UI_Playback_HlsStartLive}" Margin="0,8,0,0"/>
                <TextBlock Grid.Row="9" Grid.Column="0" Text="{DynamicResource UI_Playback_HlsReadahead}" VerticalAlignment="Center" Margin="0,8,16,0"/>
                <TextBox x:Name="TbHlsReadahead" Grid.Row="9" Grid.Column="1" Height="30" />
                <TextBlock Grid.Row="10" Grid.ColumnSpan="2" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,2,0,0"
                           Text="{DynamicResource UI_Playback_HlsHint}" TextWrapping="Wrap"/>

                <!-- Language preferences -->
                <TextBlock Grid.Row="11" Grid.Column="0" Text="{DynamicResource UI_Playback_Alang}" VerticalAlignment="Center" Margin="0,8,16,0"/>
                <TextBox x:Name="TbAlang" Grid.Row="11" Grid.Column="1" Height="30"/>
                <TextBlock Grid.Row="12" Grid.Column="0" Text="{DynamicResource UI_Playback_Slang}" VerticalAlignment="Center" Margin="0,8,16,0"/>
                <TextBox x:Name="TbSlang" Grid.Row="12" Grid.Column="1" Height="30"/>
                <TextBlock Grid.Row="13" Grid.ColumnSpan="2" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,2,0,0"
                           Text="{DynamicResource UI_Playback_LangHint}" TextWrapping="Wrap"/>

                <!-- mpv network-timeout -->
                <TextBlock Grid.Row="14" Grid.Column="0" Text="{DynamicResource UI_Playback_MpvNetworkTimeout}" VerticalAlignment="Center" Margin="0,8,16,0"/>
                <TextBox x:Name="TbMpvTimeout" Grid.Row="14" Grid.Column="1" Height="30"/>
                <TextBlock Grid.Row="15" Grid.ColumnSpan="2" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,2,0,0"
                           Text="{DynamicResource UI_Playback_MpvTimeoutHint}" TextWrapping="Wrap"/>
              </Grid>
            </ScrollViewer>
          </TabItem>

          <!-- EPG Config -->
          <TabItem x:Name="TabEpg" Header="{DynamicResource UI_Epg_Config}">
              <controls:EpgDrawer x:Name="EpgSettingsControl"/>
          </TabItem>

          <!-- Logo Config -->
          <TabItem x:Name="TabLogo" Header="{DynamicResource UI_Logo_Config}">
              <controls:LogoDrawer x:Name="LogoSettingsControl"/>
          </TabItem>

          <!-- Playback (Replay) Settings -->
          <TabItem x:Name="TabReplay" Header="{DynamicResource UI_Playback_Settings}">
              <controls:PlaybackDrawer x:Name="ReplaySettingsControl"/>
          </TabItem>

          <!-- Timeshift Settings -->
          <TabItem x:Name="TabTimeshift" Header="{DynamicResource UI_Timeshift_Settings}">
              <controls:TimeshiftDrawer x:Name="TimeshiftSettingsControl"/>
          </TabItem>

          <!-- 时间覆盖（仅替换时间片段） -->
          <TabItem x:Name="TabTimeOverride" Header="{DynamicResource UI_TimeOverride_Tab}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
              <Grid Margin="16,8,16,8">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <CheckBox x:Name="CbTimeOverrideEnabled" Grid.Row="0" Grid.ColumnSpan="2" Content="{DynamicResource UI_TimeOverride_Enable}" Margin="0,0,0,12"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource UI_TimeOverride_Mode}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <ComboBox x:Name="CbTimeOverrideMode" Grid.Row="1" Grid.Column="1" Height="30" Width="220">
                  <ComboBoxItem Content="{DynamicResource UI_TimeOverride_Mode_TimeOnly}" Tag="time_only"/>
                  <ComboBoxItem Content="{DynamicResource UI_TimeOverride_Mode_ReplaceAll}" Tag="replace_all"/>
                </ComboBox>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource UI_TimeOverride_Layout}" VerticalAlignment="Center" Margin="0,8,16,0"/>
                <ComboBox x:Name="CbTimeLayout" Grid.Row="2" Grid.Column="1" Height="30" Width="220" Margin="0,8,0,0" ToolTip="{DynamicResource UI_TimeOverride_Layout_Tip}">
                  <ComboBoxItem Content="{DynamicResource UI_TimeOverride_Layout_StartEnd}" Tag="start_end"/>
                  <ComboBoxItem Content="{DynamicResource UI_TimeOverride_Layout_Playseek}" Tag="playseek"/>
                  <ComboBoxItem Content="{DynamicResource UI_TimeOverride_Layout_StartDuration}" Tag="start_duration"/>
                </ComboBox>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource UI_TimeOverride_Encoding}" VerticalAlignment="Center" Margin="0,8,16,0"/>
                <ComboBox x:Name="CbTimeEncoding" Grid.Row="3" Grid.Column="1" Height="30" Width="220" Margin="0,8,0,0" ToolTip="{DynamicResource UI_TimeOverride_Encoding_Tip}">
                  <ComboBoxItem Content="{DynamicResource UI_TimeOverride_Encoding_Local}" Tag="local"/>
                  <ComboBoxItem Content="{DynamicResource UI_TimeOverride_Encoding_Utc}" Tag="utc"/>
                  <ComboBoxItem Content="{DynamicResource UI_TimeOverride_Encoding_Unix}" Tag="unix"/>
                  <ComboBoxItem Content="{DynamicResource UI_TimeOverride_Encoding_UnixMs}" Tag="unix_ms"/>
                </ComboBox>

                <TextBlock x:Name="LblStartKey" Grid.Row="4" Grid.Column="0" Text="{DynamicResource UI_TimeOverride_StartKey}" VerticalAlignment="Center" Margin="0,8,16,0"/>
                <ComboBox x:Name="CbStartKey" Grid.Row="4" Grid.Column="1" Height="30" Margin="0,8,0,0" IsEditable="True" ToolTip="{DynamicResource UI_TimeOverride_Key_Tip}">
                  <ComboBoxItem Content="start"/>
                  <ComboBoxItem Content="starttime"/>
                  <ComboBoxItem Content="begin"/>
                </ComboBox>

                <TextBlock x:Name="LblEndKey" Grid.Row="5" Grid.Column="0" Text="{DynamicResource UI_TimeOverride_EndKey}" VerticalAlignment="Center" Margin="0,8,16,0"/>
                <ComboBox x:Name="CbEndKey" Grid.Row="5" Grid.Column="1" Height="30" Margin="0,8,0,0" IsEditable="True" ToolTip="{DynamicResource UI_TimeOverride_Key_Tip}">
                  <ComboBoxItem Content="end"/>
                  <ComboBoxItem Content="endtime"/>
                  <ComboBoxItem Content="finish"/>
                </ComboBox>

                <TextBlock x:Name="LblDurationKey" Grid.Row="6" Grid.Column="0" Text="{DynamicResource UI_TimeOverride_DurationKey}" VerticalAlignment="Center" Margin="0,8,16,0"/>
                <ComboBox x:Name="CbDurationKey" Grid.Row="6" Grid.Column="1" Height="30" Margin="0,8,0,0" IsEditable="True" ToolTip="{DynamicResource UI_TimeOverride_Key_Tip}">
                  <ComboBoxItem Content="duration"/>
                  <ComboBoxItem Content="dur"/>
                  <ComboBoxItem Content="len"/>
                </ComboBox>

                <TextBlock x:Name="LblPlayseekKey" Grid.Row="7" Grid.Column="0" Text="{DynamicResource UI_TimeOverride_PlayseekKey}" VerticalAlignment="Center" Margin="0,8,16,0"/>
                <StackPanel x:Name="SpPlayseekRow" Grid.Row="7" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0">
                  <ComboBox x:Name="CbPlayseekKey" Height="30" Width="160" IsEditable="True" ToolTip="{DynamicResource UI_TimeOverride_Key_Tip}">
                    <ComboBoxItem Content="playseek"/>
                  </ComboBox>
                  <CheckBox x:Name="CbUrlEncode" Content="{DynamicResource UI_TimeOverride_UrlEncode}" Margin="12,6,0,0"/>
                </StackPanel>

                <TextBlock Grid.Row="8" Grid.ColumnSpan="2" Text="{DynamicResource UI_TimeOverride_Global_Note}" FontSize="12" Foreground="#FF3B30" Margin="0,0,0,8" TextWrapping="Wrap"/>
                <!-- Bottom container: buttons + advanced + preview, stacked to avoid overlap -->
                <StackPanel Grid.Row="9" Grid.ColumnSpan="2">
                  <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button x:Name="BtnOpenDocs" Content="{DynamicResource UI_OpenDocs}" Width="96" Click="BtnOpenDocs_Click" Style="{StaticResource ChipButton}" Margin="0,0,8,0"/>
                    <Button x:Name="BtnOpenIssues" Content="Issues" Width="96" Click="BtnOpenIssues_Click" Style="{StaticResource ChipButton}"/>
                  </StackPanel>
                  
                  <GroupBox Header="{DynamicResource UI_Advanced_Options}" Margin="0,8,0,0" BorderBrush="{DynamicResource BorderBrushCommon}">
                    <StackPanel Margin="8">
                      <TextBlock Text="{DynamicResource UI_Advanced_Desc}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap"/>
                      <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="{DynamicResource UI_Advanced_IsoPreset}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <ComboBox x:Name="CbIsoPreset" Width="220" IsEnabled="False">
                          <ComboBoxItem Content="ISO-8601 UTC (Z)"/>
                          <ComboBoxItem Content="ISO-8601 K (auto Z/offset)"/>
                          <ComboBoxItem Content="ISO-8601 +zzz"/>
                        </ComboBox>
                      </StackPanel>
                      <CheckBox x:Name="CbSplitDateTime" Content="{DynamicResource UI_Advanced_Split}" IsEnabled="False" Margin="0,6,0,0"/>
                      <CheckBox x:Name="CbPathPlaceholder" Content="{DynamicResource UI_Advanced_Path}" IsEnabled="False" Margin="0,6,0,0"/>
                    </StackPanel>
                  </GroupBox>
                  
                  <GroupBox Header="{DynamicResource UI_TimeOverride_Preview_Group}" Margin="0,12,0,0" BorderBrush="{DynamicResource BorderBrushCommon}">
                    <StackPanel Margin="8">
                      <TextBlock Text="{DynamicResource UI_TimeOverride_Preview_BaseUrl}" FontWeight="SemiBold"/>
                      <TextBox x:Name="TbBaseUrl" Height="30" Margin="0,6,0,8"/>
                      <StackPanel Orientation="Horizontal">
                        <Button x:Name="BtnPreviewReplay" Content="{DynamicResource UI_TimeOverride_Preview_Replay}" Width="96" Click="BtnPreviewReplay_Click" Style="{StaticResource ChipButton}"/>
                        <Button x:Name="BtnPreviewTimeshift" Content="{DynamicResource UI_TimeOverride_Preview_Timeshift}" Width="96" Margin="8,0,0,0" Click="BtnPreviewTimeshift_Click" Style="{StaticResource ChipButton}"/>
                      </StackPanel>
                      <TextBox x:Name="TbPreviewResult" Height="90" Margin="0,8,0,0" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                      <TextBlock Text="{DynamicResource UI_TimeOverride_Preview_Template}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                      <TextBox x:Name="TbPreviewTemplate" Height="74" Margin="0,6,0,0" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>
                  </GroupBox>
                </StackPanel>
              </Grid>
            </ScrollViewer>
          </TabItem>
          <!-- 更新与镜像 -->
          <TabItem Header="{DynamicResource UI_TabUpdateMirrors}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
              <Grid Margin="16,8,16,8">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource UI_CdnLines}" VerticalAlignment="Top" Margin="0,0,16,0" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <StackPanel Grid.Row="0" Grid.Column="1">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="{DynamicResource UI_Cdn_Help}" Grid.Row="0" Grid.ColumnSpan="2" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8" TextWrapping="Wrap"/>
                        <TextBox x:Name="TbNewCdn" Grid.Row="1" Height="30" Grid.Column="0" ToolTip="{DynamicResource UI_Cdn_Example}"/>
                        <Button Grid.Row="1" Grid.Column="1" Content="{DynamicResource UI_Add}" Width="68" Margin="8,0,0,0" Click="BtnCdnAdd_Click" Style="{StaticResource ChipButton}"/>
                  </Grid>
                  <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ListBox x:Name="ListCdn" Grid.Column="0" Height="160" />
                    <StackPanel Grid.Column="1" Orientation="Vertical" Margin="8,0,0,0">
                          <Button Content="{DynamicResource UI_MoveUp}" Width="68" Click="BtnCdnUp_Click" Style="{StaticResource ChipButton}"/>
                          <Button Content="{DynamicResource UI_MoveDown}" Width="68" Margin="0,6,0,0" Click="BtnCdnDown_Click" Style="{StaticResource ChipButton}"/>
                          <Button Content="{DynamicResource UI_Delete}" Width="68" Margin="0,6,0,0" Click="BtnCdnRemove_Click" Style="{StaticResource ChipButton}"/>
                          <Button Content="{DynamicResource UI_SortBySpeed}" Width="68" Margin="0,6,0,0" Click="BtnCdnSpeedTest_Click" Style="{StaticResource ChipButton}"/>
                    </StackPanel>
                  </Grid>
                </StackPanel>
              </Grid>
            </ScrollViewer>
          </TabItem>

          <!-- 关于 -->
          <TabItem Header="{DynamicResource UI_TabAbout}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
              <StackPanel Margin="16,12,16,12">
                <Border Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource BorderBrushCommon}" BorderThickness="1" CornerRadius="8" Padding="16">
                  <StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                      <Image Source="/srcbox.png" Width="28" Height="28" Margin="0,0,8,0"/>
                      <TextBlock Text="{DynamicResource App_Name}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Center">
                      <TextBlock x:Name="TxtVersionInline" Text="v-" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14" VerticalAlignment="Center"/>
                      <Border x:Name="BadgeNewInline" Background="#FF3B30" CornerRadius="8" Margin="8,0,0,0" Padding="8,2" Visibility="Collapsed" VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource About_NewBadge}" Foreground="White" FontSize="12" FontWeight="Bold"/>
                      </Border>
                    </StackPanel>
                    <TextBlock Text="{DynamicResource About_Desc1}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,8,0,0"/>
                    <TextBlock Text="{DynamicResource About_Desc2}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                      <Button x:Name="BtnCheckUpdateInline" Content="{DynamicResource UI_CheckUpdate}" Width="100" Height="30" Click="BtnCheckUpdateInline_Click" Style="{StaticResource ChipButton}"/>
                      <!-- <Button x:Name="BtnViewUpdate" Content="{DynamicResource UI_ViewUpdate}" Width="100" Height="30" Margin="12,0,0,0" Click="BtnViewUpdateInline_Click" Style="{StaticResource ChipButton}"/> -->
                    </StackPanel>
                  </StackPanel>
                </Border>
                <Border Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource BorderBrushCommon}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,12,0,0">
                  <StackPanel>
                    <TextBlock Text="{DynamicResource UI_ProjectSupport}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Left">
                      <TextBlock>
                        <Hyperlink NavigateUri="https://github.com/CGG888/SrcBox" RequestNavigate="Inline_RequestNavigate" Foreground="#FFC107">
                          <Run Text="{DynamicResource UI_GitHubHome}"/>
                        </Hyperlink>
                      </TextBlock>
                      <TextBlock Text="  |  " Foreground="{DynamicResource TextSecondaryBrush}" Margin="6,0,6,0"/>
                      <TextBlock>
                        <Hyperlink NavigateUri="https://github.com/CGG888/SrcBox/issues" RequestNavigate="Inline_RequestNavigate" Foreground="#FFC107">
                          <Run Text="{DynamicResource UI_Feedback}"/>
                        </Hyperlink>
                      </TextBlock>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                      <Button x:Name="BtnLicense" Content="{DynamicResource UI_License}" Width="100" Height="30" Click="BtnLicense_Click" Style="{StaticResource ChipButton}"/>
                      <Button x:Name="BtnThirdParty" Content="{DynamicResource UI_ThirdParty}" Width="100" Height="30" Margin="12,0,0,0" Click="BtnThirdParty_Click" Style="{StaticResource ChipButton}"/>
                    </StackPanel>
                  </StackPanel>
                </Border>
              </StackPanel>
            </ScrollViewer>
          </TabItem>
        </TabControl>

        <!-- 底部操作条 -->
        <DockPanel Grid.Row="1" LastChildFill="False" Margin="0,16,0,0">
          <Button Width="96" Margin="0,0,12,0" Content="{DynamicResource UI_DebugLog}" Click="BtnDebug_Click" DockPanel.Dock="Right" Style="{StaticResource ChipButton}"/>
          <Button Width="96" Margin="0,0,12,0" Content="{DynamicResource UI_Save}" IsDefault="True" Click="BtnSave_Click" DockPanel.Dock="Right" Style="{StaticResource AccentButtonStyle}"/>
          <Button Width="96" Content="{DynamicResource UI_Cancel}" IsCancel="True" Click="BtnCancel_Click" DockPanel.Dock="Right" Style="{StaticResource ChipButton}"/>
        </DockPanel>
      </Grid>
    </Grid>
  </Border>
</Window>
