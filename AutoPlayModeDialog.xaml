<Window x:Class="LibmpvIptvClient.AutoPlayModeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择播放模式" Width="360" Height="160" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Background="{DynamicResource CardBackgroundBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}">
  <Border Margin="16" Padding="12" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8">
    <StackPanel>
      <TextBlock Text="自动播放时选择模式" Margin="0,0,0,12"/>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" >
        <Button x:Name="BtnDefault" Content="默认" Width="88" Margin="6,0" Click="BtnDefault_Click" Style="{StaticResource ChipButton}"/>
        <Button x:Name="BtnWindow" Content="窗口" Width="88" Margin="6,0" Click="BtnWindow_Click" Style="{StaticResource ChipButton}"/>
        <Button x:Name="BtnFullscreen" Content="全屏" Width="88" Margin="6,0" Click="BtnFullscreen_Click" Style="{StaticResource ChipButton}"/>
      </StackPanel>
    </StackPanel>
  </Border>
</Window>
