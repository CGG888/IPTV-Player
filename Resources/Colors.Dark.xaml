<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <SolidColorBrush x:Key="AppBackgroundBrush" Color="#1F1F1F"/>
  <SolidColorBrush x:Key="TitleBarBrush" Color="#252525"/>
  <SolidColorBrush x:Key="CardBackgroundBrush" Color="#202020"/>
  <SolidColorBrush x:Key="BorderBrushCommon" Color="#333333"/>
  <SolidColorBrush x:Key="DividerBrush" Color="#333333"/>
  <SolidColorBrush x:Key="TextPrimaryBrush" Color="#EEEEEE"/>
  <SolidColorBrush x:Key="TextSecondaryBrush" Color="#CCCCCC"/>

  <SolidColorBrush x:Key="ChipButtonBackgroundBrush" Color="#333333"/>
  <SolidColorBrush x:Key="ChipButtonBorderBrush" Color="#444444"/>
  <SolidColorBrush x:Key="ChipButtonHoverBrush" Color="#2E2E2E"/>
  <SolidColorBrush x:Key="ChipButtonPressedBrush" Color="#212121"/>

  <!-- Input Fields -->
  <SolidColorBrush x:Key="InputBackgroundBrush" Color="#333333"/>
  <SolidColorBrush x:Key="InputTextBrush" Color="#FFFFFF"/>
  <SolidColorBrush x:Key="InputBorderBrush" Color="#555555"/>

  <!-- Buttons -->
  <SolidColorBrush x:Key="PrimaryButtonBackgroundBrush" Color="#0078D7"/>
  <SolidColorBrush x:Key="PrimaryButtonForegroundBrush" Color="#FFFFFF"/>
  <SolidColorBrush x:Key="SecondaryButtonBackgroundBrush" Color="#444444"/>
  <SolidColorBrush x:Key="SecondaryButtonForegroundBrush" Color="#FFFFFF"/>
  <SolidColorBrush x:Key="DangerButtonBackgroundBrush" Color="#D70000"/>
  <SolidColorBrush x:Key="DangerButtonForegroundBrush" Color="#FFFFFF"/>

  <!-- Slider -->
  <SolidColorBrush x:Key="AccentBrush" Color="#FF35C759"/>
  <SolidColorBrush x:Key="SliderInactiveBrush" Color="#333333"/>
  <SolidColorBrush x:Key="SliderThumbFillBrush" Color="#FFFFFF"/>
  <SolidColorBrush x:Key="SliderThumbStrokeBrush" Color="#101010"/>

  <!-- Interactive States -->
  <SolidColorBrush x:Key="ButtonHoverBackgroundBrush" Color="#19FFFFFF"/>
  <SolidColorBrush x:Key="ButtonPressedBackgroundBrush" Color="#33FFFFFF"/>
  
  <!-- Overlay -->
  <SolidColorBrush x:Key="OverlayBackgroundBrush" Color="#CC000000"/>
  <SolidColorBrush x:Key="StatusIndicatorBackgroundBrush" Color="#80000000"/>
  
  <!-- Status Colors -->
  <SolidColorBrush x:Key="StatusLiveBrush" Color="#FF453A"/>
  <SolidColorBrush x:Key="StatusReplayBrush" Color="#32CD32"/>
  <SolidColorBrush x:Key="StatusTimeshiftBrush" Color="#FF9F0A"/>
  <SolidColorBrush x:Key="StatusBookBrush" Color="#0A84FF"/>
</ResourceDictionary>
