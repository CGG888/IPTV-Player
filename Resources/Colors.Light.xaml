<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <SolidColorBrush x:Key="AppBackgroundBrush" Color="#FAFAFA"/>
  <SolidColorBrush x:Key="TitleBarBrush" Color="#F0F0F0"/>
  <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
  <SolidColorBrush x:Key="BorderBrushCommon" Color="#D9D9D9"/>
  <SolidColorBrush x:Key="DividerBrush" Color="#DDDDDD"/>
  <SolidColorBrush x:Key="TextPrimaryBrush" Color="#111111"/>
  <SolidColorBrush x:Key="TextSecondaryBrush" Color="#666666"/>

  <SolidColorBrush x:Key="ChipButtonBackgroundBrush" Color="#EEEEEE"/>
  <SolidColorBrush x:Key="ChipButtonBorderBrush" Color="#DDDDDD"/>
  <SolidColorBrush x:Key="ChipButtonHoverBrush" Color="#E6E6E6"/>
  <SolidColorBrush x:Key="ChipButtonPressedBrush" Color="#DDDDDD"/>

  <!-- Input Fields -->
  <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFF"/>
  <SolidColorBrush x:Key="InputTextBrush" Color="#111111"/>
  <SolidColorBrush x:Key="InputBorderBrush" Color="#CCCCCC"/>

  <!-- Buttons -->
  <SolidColorBrush x:Key="PrimaryButtonBackgroundBrush" Color="#0078D7"/>
  <SolidColorBrush x:Key="PrimaryButtonForegroundBrush" Color="#FFFFFF"/>
  <SolidColorBrush x:Key="SecondaryButtonBackgroundBrush" Color="#E0E0E0"/>
  <SolidColorBrush x:Key="SecondaryButtonForegroundBrush" Color="#111111"/>
  <SolidColorBrush x:Key="DangerButtonBackgroundBrush" Color="#D70000"/>
  <SolidColorBrush x:Key="DangerButtonForegroundBrush" Color="#FFFFFF"/>

  <!-- Slider -->
  <SolidColorBrush x:Key="AccentBrush" Color="#FF35C759"/>
  <SolidColorBrush x:Key="SliderInactiveBrush" Color="#AAAAAA"/>
  <SolidColorBrush x:Key="SliderThumbFillBrush" Color="#FFFFFF"/>
  <SolidColorBrush x:Key="SliderThumbStrokeBrush" Color="#DDDDDD"/>

  <!-- Interactive States -->
  <SolidColorBrush x:Key="ButtonHoverBackgroundBrush" Color="#19000000"/>
  <SolidColorBrush x:Key="ButtonPressedBackgroundBrush" Color="#33000000"/>
  
  <!-- Overlay -->
  <SolidColorBrush x:Key="OverlayBackgroundBrush" Color="#CCFFFFFF"/>
  <SolidColorBrush x:Key="StatusIndicatorBackgroundBrush" Color="#80FFFFFF"/>
  
  <!-- Status Colors -->
  <SolidColorBrush x:Key="StatusLiveBrush" Color="#D70000"/>
  <SolidColorBrush x:Key="StatusReplayBrush" Color="#00A000"/>
  <SolidColorBrush x:Key="StatusTimeshiftBrush" Color="#00A8A8"/>
  <SolidColorBrush x:Key="StatusBookBrush" Color="#0050C0"/>
  
  <!-- Filled Chips -->
  <SolidColorBrush x:Key="StatusLiveFillBrush" Color="#D70000"/>
  <SolidColorBrush x:Key="StatusReplayFillBrush" Color="#00A000"/>
  <SolidColorBrush x:Key="StatusTimeshiftFillBrush" Color="#00A8A8"/>
  
  <LinearGradientBrush x:Key="TopOverlayScrimBrush" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="#BF000000" Offset="0"/>
    <GradientStop Color="#00000000" Offset="1"/>
  </LinearGradientBrush>
</ResourceDictionary>
