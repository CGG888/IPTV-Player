<Window x:Class="LibmpvIptvClient.ModernMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        Title="Message"
        Height="220" Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        KeyDown="Window_KeyDown">
    
    <Border Background="{DynamicResource AppBackgroundBrush}" BorderBrush="{DynamicResource BorderBrushCommon}" BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0" Background="{DynamicResource TitleBarBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtTitle" Text="Title" Foreground="{DynamicResource TextPrimaryBrush}" Margin="16,10" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                <Button x:Name="BtnClose" Grid.Column="1" Content="✕" Width="28" Height="28" Margin="0,4,4,4"
                        Background="Transparent" BorderBrush="Transparent" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                        Click="BtnClose_Click" ToolTip="{DynamicResource Common_Close}"/>
            </Grid>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="24,16">
                <TextBlock x:Name="TxtMessage" Text="Message Content" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" FontSize="15" Margin="0,0,0,12" LineHeight="22"/>
                
                <!-- Link for About dialog -->
                <TextBlock x:Name="TxtLink" Visibility="Collapsed" Margin="0,8,0,0">
                    <Hyperlink NavigateUri="https://github.com/your-repo" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#FFC107">
                        <TextBlock Text="GitHub Repository"/>
                    </Hyperlink>
                </TextBlock>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="16">
                <Button x:Name="BtnYes" Content="{DynamicResource Common_OK}" Style="{StaticResource AccentButtonStyle}" Width="80" Margin="0,0,8,0" Click="BtnYes_Click" Visibility="Collapsed"/>
                <Button x:Name="BtnNo" Content="{DynamicResource Common_Cancel}" Width="80" Click="BtnNo_Click" Visibility="Collapsed" Style="{StaticResource ChipButton}"/>
                <Button x:Name="BtnOk" Content="{DynamicResource Common_OK}" Style="{StaticResource AccentButtonStyle}" Width="80" Click="BtnOk_Click" Visibility="Collapsed"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
