<Window x:Class="LibmpvIptvClient.ModernMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        Title="Message"
        Height="200" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">
    
    <Border Background="{DynamicResource AppBackgroundBrush}" BorderBrush="{DynamicResource BorderBrushCommon}" BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0" Background="{DynamicResource TitleBarBrush}">
                <TextBlock x:Name="TxtTitle" Text="Title" Foreground="{DynamicResource TextPrimaryBrush}" Margin="16,12" FontWeight="SemiBold"/>
            </Grid>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="24,20">
                <TextBlock x:Name="TxtMessage" Text="Message Content" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" FontSize="14" Margin="0,0,0,12"/>
                
                <!-- Link for About dialog -->
                <TextBlock x:Name="TxtLink" Visibility="Collapsed" Margin="0,8,0,0">
                    <Hyperlink NavigateUri="https://github.com/your-repo" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#FFC107">
                        <TextBlock Text="GitHub Repository"/>
                    </Hyperlink>
                </TextBlock>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="16">
                <Button x:Name="BtnYes" Content="{DynamicResource Common_OK}" Style="{StaticResource AccentButtonStyle}" Width="80" Margin="0,0,8,0" Click="BtnYes_Click" Visibility="Collapsed"/>
                <Button x:Name="BtnNo" Content="{DynamicResource Common_Cancel}" Width="80" Click="BtnNo_Click" Visibility="Collapsed" Style="{StaticResource ChipButton}"/>
                <Button x:Name="BtnOk" Content="{DynamicResource Common_OK}" Style="{StaticResource AccentButtonStyle}" Width="80" Click="BtnOk_Click" Visibility="Collapsed"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
