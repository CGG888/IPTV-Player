<Window x:Class="LibmpvIptvClient.Controls.DeleteRecordingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="ToolWindow" ResizeMode="NoResize" SizeToContent="WidthAndHeight"
        Background="{DynamicResource CardBackgroundBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
        ShowInTaskbar="False" Topmost="True" WindowStartupLocation="CenterOwner" Width="360">
  <Border Padding="16" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource BorderBrushCommon}" BorderThickness="1">
    <StackPanel>
      <TextBlock x:Name="TxtTitle" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
      <TextBlock x:Name="TxtDesc" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,12"/>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button x:Name="BtnDeleteLocal" Width="100" Height="30" Margin="0,0,8,0" />
        <Button x:Name="BtnDeleteRemote" Width="100" Height="30" Margin="0,0,8,0" />
        <Button x:Name="BtnDeleteBoth" Width="100" Height="30" />
      </StackPanel>
    </StackPanel>
  </Border>
</Window>
