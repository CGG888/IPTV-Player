<Window x:Class="LibmpvIptvClient.ReminderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Reminder_Title}" Width="360" Height="240" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Background="{DynamicResource AppBackgroundBrush}">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <TextBlock x:Name="TxtTitle" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
    <TextBlock x:Name="TxtTime" Grid.Row="1" Margin="0,6,0,12" Foreground="{DynamicResource TextSecondaryBrush}"/>
    <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,8,0,8">
      <TextBlock Text="{DynamicResource Reminder_PreAlert}" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
      <TextBox x:Name="TbPreAlert" Width="80" Height="28" Margin="8,0,0,0" Text="60"/>
    </StackPanel>
    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
      <Button x:Name="BtnNotify" Content="{DynamicResource Reminder_Notify}" Width="96" Margin="0,0,8,0" Click="BtnNotify_Click" Style="{StaticResource AccentButtonStyle}"/>
      <Button x:Name="BtnAutoplay" Content="{DynamicResource Reminder_Autoplay}" Width="96" Margin="0,0,8,0" IsEnabled="False"/>
      <Button x:Name="BtnRecord" Content="{DynamicResource Reminder_Record}" Width="96" IsEnabled="False"/>
    </StackPanel>
  </Grid>
</Window>
