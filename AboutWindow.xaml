<Window x:Class="LibmpvIptvClient.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="关于"
        Height="360" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">

    <Border Background="#1F1F1F" BorderBrush="#333" BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0" Background="#252525">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Image Source="iptv.ico" Width="16" Height="16" Margin="0,0,8,0"/>
                    <TextBlock Text="关于 IPTV Player" Foreground="#DDD" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0" 
                        Background="Transparent" Foreground="#999" BorderThickness="0" 
                        Width="30" Height="30" Click="BtnClose_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#C42B1C"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="32,24" HorizontalAlignment="Center">
                <!-- Logo & App Name -->
                <Image Source="iptv.ico" Width="64" Height="64" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                <TextBlock Text="IPTV Player" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,24">
                    <TextBlock x:Name="TxtVersion" Text="v1.0.0" Foreground="#AAA" FontSize="14" VerticalAlignment="Center"/>
                    <Ellipse x:Name="BadgeNew" Width="8" Height="8" Fill="#FF3B30" Margin="6,0,0,0" VerticalAlignment="Center" Visibility="Collapsed"/>
                </StackPanel>

                <!-- Description -->
                <TextBlock Text="基于 libmpv 开发的高性能 Windows IPTV 播放器。" Foreground="#CCC" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="支持 M3U 播放列表、EPG 节目指南、回看等功能。" Foreground="#CCC" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,24"/>

                <!-- Links -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock>
                        <Hyperlink NavigateUri="https://github.com/CGG888/IPTV-Player" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#FFC107">
                            GitHub 项目主页
                        </Hyperlink>
                    </TextBlock>
                    <TextBlock Text="  |  " Foreground="#666"/>
                    <TextBlock>
                        <Hyperlink NavigateUri="https://github.com/CGG888/IPTV-Player/issues" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#FFC107">
                            反馈问题
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </StackPanel>

            <!-- Bottom Buttons -->
            <Grid Grid.Row="2" Margin="24,0,24,24">
                <Button Content="更新" HorizontalAlignment="Left" Style="{StaticResource AccentButtonStyle}" Width="100" Click="BtnUpdate_Click"/>
                <Button Content="确定" HorizontalAlignment="Right" Width="80" Click="BtnClose_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
