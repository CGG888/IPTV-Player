<Window x:Class="LibmpvIptvClient.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource UI_TabAbout}"
        Height="360" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="{DynamicResource AppBackgroundBrush}"
        ShowInTaskbar="True"
        Icon="pack://application:,,,/srcbox.ico">

    <Border Background="{DynamicResource AppBackgroundBrush}" BorderBrush="{DynamicResource BorderBrushCommon}" BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0" Background="{DynamicResource TitleBarBrush}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Image Source="srcbox.ico" Width="16" Height="16" Margin="0,0,8,0"/>
                    <TextBlock Text="{DynamicResource About_TitleBar}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0" 
                        Background="Transparent" Foreground="{DynamicResource TextSecondaryBrush}" BorderThickness="0" 
                        Width="30" Height="30" Click="BtnClose_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource DangerButtonBackgroundBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="32,24" HorizontalAlignment="Center">
                <!-- Logo & App Name -->
                <Image Source="srcbox.ico" Width="64" Height="64" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                <TextBlock Text="{DynamicResource App_Name}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,24">
                    <TextBlock x:Name="TxtVersion" Text="v1.0.0" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14" VerticalAlignment="Center"/>
                    <Ellipse x:Name="BadgeNew" Width="8" Height="8" Fill="{DynamicResource StatusLiveBrush}" Margin="6,0,0,0" VerticalAlignment="Center" Visibility="Collapsed"/>
                </StackPanel>

                <!-- Description -->
                <TextBlock Text="{DynamicResource About_Desc1}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="{DynamicResource About_Desc2}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,24"/>

                <!-- Links -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock>
                        <Hyperlink NavigateUri="https://github.com/CGG888/SrcBox" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource AccentBrush}">
                            <Run Text="{DynamicResource UI_GitHubHome}"/>
                        </Hyperlink>
                    </TextBlock>
                    <TextBlock Text="  |  " Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock>
                        <Hyperlink NavigateUri="https://github.com/CGG888/SrcBox/issues" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource AccentBrush}">
                            <Run Text="{DynamicResource UI_Feedback}"/>
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </StackPanel>

            <!-- Bottom Buttons -->
            <Grid Grid.Row="2" Margin="24,0,24,24">
                <Button Content="{DynamicResource About_Update}" HorizontalAlignment="Left" Style="{StaticResource AccentButtonStyle}" Width="100" Click="BtnUpdate_Click"/>
                <Button Content="{DynamicResource Common_OK}" HorizontalAlignment="Right" Width="80" Click="BtnClose_Click" Style="{StaticResource ChipButton}"/>
            </Grid>
        </Grid>
    </Border>
</Window>
