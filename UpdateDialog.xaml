<Window x:Class="LibmpvIptvClient.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="更新" Height="420" Width="560" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" WindowStyle="None" Background="Transparent" ShowInTaskbar="False">
    <Border Background="#1F1F1F" BorderBrush="#333" BorderThickness="1" CornerRadius="8">
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Background="#252525" Height="40">
                <TextBlock Text="软件更新" Foreground="#DDD" Margin="16,0,0,0" VerticalAlignment="Center"/>
                <Button Content="✕" Width="30" Height="30" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0"
                        Background="Transparent" Foreground="#999" BorderThickness="0" Click="BtnClose_Click"/>
            </Grid>
            <Grid Grid.Row="1" Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="最新版本：" Foreground="#CCC" Margin="0,0,6,0"/>
                    <TextBlock x:Name="TxtNewVer" Foreground="#FFC107" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,8">
                    <TextBlock Text="下载线路：" Foreground="#CCC" VerticalAlignment="Center"/>
                    <ComboBox x:Name="CbMirrors" Width="360" Margin="8,0,0,0"/>
                </StackPanel>
                <GroupBox Grid.Row="2" Header="更新内容" Foreground="#DDD" BorderBrush="#333" Background="#1A1A1A">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="TxtNotes" Foreground="#CCC" TextWrapping="Wrap" Margin="8" />
                    </ScrollViewer>
                </GroupBox>
                <Grid Grid.Row="3" Margin="0,8,0,8" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ProgressBar x:Name="Pb" Grid.Column="0" Height="12" Margin="0,0,8,0"/>
                    <TextBlock x:Name="TxtProgress" Grid.Column="1" Foreground="#CCC" TextAlignment="Right"
                               FontFamily="Consolas" FontSize="12" VerticalAlignment="Center"
                               Margin="0,0,0,0" />
                </Grid>
                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnDownload" Content="下载" Width="80" Margin="0,0,8,0" Click="BtnDownload_Click"/>
                    <Button x:Name="BtnInstall" Content="安装更新" Width="100" IsEnabled="False" Click="BtnInstall_Click"/>
                </StackPanel>
            </Grid>
            <Grid Grid.Row="2" Margin="16,0,16,16"/>
        </Grid>
    </Border>
</Window>
