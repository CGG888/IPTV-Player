<Window x:Class="LibmpvIptvClient.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Update_Title}" Height="420" Width="560" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" WindowStyle="None" Background="Transparent" ShowInTaskbar="False">
    <Border Background="{DynamicResource AppBackgroundBrush}" BorderBrush="{DynamicResource BorderBrushCommon}" BorderThickness="1" CornerRadius="8">
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Background="{DynamicResource TitleBarBrush}" Height="40">
                <TextBlock Text="{DynamicResource Update_Title}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="16,0,0,0" VerticalAlignment="Center"/>
                <Button Content="✕" Width="30" Height="30" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0"
                        Background="Transparent" Foreground="#999" BorderThickness="0" Click="BtnClose_Click"/>
            </Grid>
            <Grid Grid.Row="1" Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource Update_LatestVersion}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,6,0"/>
                    <TextBlock x:Name="TxtNewVer" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,8">
                    <TextBlock Text="{DynamicResource Update_DownloadLine}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    <ComboBox x:Name="CbMirrors" Width="360" Margin="8,0,0,0"/>
                </StackPanel>
                <GroupBox Grid.Row="2" Header="{DynamicResource Update_Notes}" Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource BorderBrushCommon}" Background="{DynamicResource CardBackgroundBrush}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="TxtNotes" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="8" />
                    </ScrollViewer>
                </GroupBox>
                <Grid Grid.Row="3" Margin="0,8,0,8" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ProgressBar x:Name="Pb" Grid.Column="0" Height="12" Margin="0,0,8,0"/>
                    <TextBlock x:Name="TxtProgress" Grid.Column="1" Foreground="{DynamicResource TextSecondaryBrush}" TextAlignment="Right"
                               FontFamily="Consolas" FontSize="12" VerticalAlignment="Center"
                               Margin="0,0,0,0" />
                </Grid>
                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnDownload" Content="{DynamicResource Update_Download}" Width="96" Margin="0,0,8,0" Click="BtnDownload_Click" Style="{StaticResource ChipButton}"/>
                    <Button x:Name="BtnInstall" Content="{DynamicResource Update_Install}" Width="100" IsEnabled="False" Click="BtnInstall_Click" Style="{StaticResource AccentButtonStyle}"/>
                </StackPanel>
            </Grid>
            <Grid Grid.Row="2" Margin="16,0,16,16"/>
        </Grid>
    </Border>
</Window>
