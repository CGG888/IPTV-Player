<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
        xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        xmlns:local="clr-namespace:LibmpvIptvClient"
        xmlns:helpers="clr-namespace:LibmpvIptvClient.Helpers"
        x:Class="LibmpvIptvClient.MainWindow"
        Title="{DynamicResource App_Name}" Width="1280" Height="720" WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow" ResizeMode="CanResize"
        Icon="pack://application:,,,/srcbox.ico">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" GlassFrameThickness="0" CornerRadius="0" ResizeBorderThickness="4" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.Style>
            <Style TargetType="Grid">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=WindowState}" Value="Maximized">
                        <Setter Property="Margin" Value="8"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>
        <Grid.Resources>
            <BitmapImage x:Key="DefaultLogo" UriSource="srcbox.ico"/>
            <local:RangeToWidthConverter x:Key="RangeToWidth"/>
            <local:BoolToStarConverter x:Key="BoolToStar"/>
            
            <!-- 基础按钮样式 -->
            <Style x:Key="BarButtonBase" TargetType="{x:Type ButtonBase}">
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Width" Value="30"/>
                <Setter Property="Height" Value="30"/>
                <Setter Property="Margin" Value="8,0,0,0"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ButtonBase}">
                            <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource ButtonHoverBackgroundBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource ButtonPressedBackgroundBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="BarButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Width" Value="46"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="FontSize" Value="12"/> <!-- Adjusted to match top icon visual size -->
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource ButtonHoverBackgroundBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource ButtonPressedBackgroundBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="BarToggle" TargetType="ToggleButton">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Width" Value="46"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="FontSize" Value="12"/> <!-- Adjusted to match top icon visual size -->
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="bd" Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource ButtonHoverBackgroundBrush}"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource ButtonPressedBackgroundBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            
            <!-- Title Bar Styles -->
            <Style x:Key="TopBtnStyle" TargetType="ButtonBase">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Width" Value="46"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ButtonBase">
                            <Border x:Name="bd" Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource ButtonHoverBackgroundBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource ButtonPressedBackgroundBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="TitleBtnStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="10,0"/>
                <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}">
                                <StackPanel Orientation="Horizontal">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBlock Text="▼" FontSize="10" Margin="6,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource ButtonHoverBackgroundBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ThickSlider" TargetType="Slider">
                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Slider">
                            <Grid Height="20" Background="Transparent">
                                <Border Height="2" CornerRadius="1" Background="{DynamicResource SliderInactiveBrush}" VerticalAlignment="Center"/>
                                <Border Height="8" CornerRadius="4" Background="{DynamicResource AccentBrush}" VerticalAlignment="Center" HorizontalAlignment="Left">
                                    <Border.Width>
                                        <MultiBinding Converter="{StaticResource RangeToWidth}">
                                            <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="ActualWidth"/>
                                            <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Value"/>
                                            <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Minimum"/>
                                            <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Maximum"/>
                                        </MultiBinding>
                                    </Border.Width>
                                </Border>
                                <Track x:Name="PART_Track">
                                    <Track.DecreaseRepeatButton>
                                        <!-- 隐藏原生填充，避免与自定义进度条重复 -->
                                        <RepeatButton Command="Slider.DecreaseLarge" Background="#00FFFFFF">
                                            <RepeatButton.Template>
                                                <ControlTemplate TargetType="RepeatButton">
                                                    <Border Height="0" Background="#00FFFFFF"/>
                                                </ControlTemplate>
                                            </RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Width="14" Height="14" VerticalAlignment="Center">
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Grid>
                                                        <Ellipse Fill="{DynamicResource SliderThumbFillBrush}" Stroke="{DynamicResource SliderThumbStrokeBrush}" StrokeThickness="1">
                                                            <Ellipse.Effect>
                                                                <DropShadowEffect ShadowDepth="0" BlurRadius="4" Opacity="0.5"/>
                                                            </Ellipse.Effect>
                                                        </Ellipse>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="Slider.IncreaseLarge" Background="#00FFFFFF">
                                            <RepeatButton.Template>
                                                <ControlTemplate TargetType="RepeatButton">
                                                    <Border Height="8" CornerRadius="4" Background="#00FFFFFF" VerticalAlignment="Center"/>
                                                </ControlTemplate>
                                            </RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="TagChip" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource ChipButtonBackgroundBrush}"/>
                <Setter Property="CornerRadius" Value="4"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ChipButtonBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="6,2"/>
                <Setter Property="Margin" Value="6,0,0,0"/>
            </Style>
            <!-- 抽屉顶部操作按钮（统一芯片风格） -->
            <Style x:Key="ActionChipButton" TargetType="{x:Type Button}">
                <Setter Property="Background" Value="{DynamicResource ChipButtonBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ChipButtonBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="12,6"/>
                <Setter Property="MinWidth" Value="82"/>
                <Setter Property="Height" Value="28"/>
                <Setter Property="HorizontalAlignment" Value="Right"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border x:Name="bd" CornerRadius="6" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource ChipButtonHoverBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource ChipButtonBorderBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource ChipButtonPressedBrush}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.6"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <local:ListIndexConverter x:Key="IndexConverter"/>
            <local:AsyncImageConverter x:Key="AsyncImage"/>
            <local:StringToVisibilityConverter x:Key="StringToVis"/>

            <!-- ContextMenu Styles -->
            <Style TargetType="{x:Type ContextMenu}">
                <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushCommon}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="HasDropShadow" Value="True"/>
                <Setter Property="Grid.IsSharedSizeScope" Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ContextMenu}">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="4">
                                <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="{x:Type MenuItem}">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                <Setter Property="Padding" Value="12,8"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type MenuItem}">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/> <!-- Fixed width to prevent jumping -->
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="Shortcut"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Icon / Checkmark Area -->
                                    <ContentPresenter x:Name="Icon" ContentSource="Icon" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                                    <Path x:Name="CheckMark" Data="M1,5 L4.5,8.5 L9,1" Stroke="{DynamicResource AccentBrush}" StrokeThickness="2" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" SnapsToDevicePixels="False"/>

                                    <!-- Content -->
                                    <ContentPresenter Grid.Column="1" ContentSource="Header" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                    
                                    <!-- Shortcut -->
                                    <TextBlock Grid.Column="2" Text="{TemplateBinding InputGestureText}" Margin="16,0,0,0" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>

                                    <!-- Arrow for Submenu -->
                                    <Path x:Name="Arrow" Grid.Column="3" Data="M0,0 L4,3.5 L0,7" Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="1" Margin="12,0,0,0" VerticalAlignment="Center" Visibility="Collapsed"/>
                                    
                                    <!-- Popup for Submenu -->
                                    <Popup x:Name="Popup" Placement="Right" IsOpen="{TemplateBinding IsSubmenuOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                                        <Border x:Name="SubmenuBorder" SnapsToDevicePixels="True" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource BorderBrushCommon}" BorderThickness="1" CornerRadius="6" Padding="4" Grid.IsSharedSizeScope="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                        </Border>
                                    </Popup>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="HasItems" Value="True">
                                    <Setter TargetName="Arrow" Property="Visibility" Value="Visible"/>
                                </Trigger>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource ChipButtonHoverBrush}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                     <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                     <Setter Property="FontWeight" Value="SemiBold"/>
                                </Trigger>
                                <Trigger Property="Icon" Value="{x:Null}">
                                    <Setter TargetName="Icon" Property="Visibility" Value="Collapsed"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="{x:Type Separator}">
                <Setter Property="Background" Value="{DynamicResource DividerBrush}"/>
                <Setter Property="Height" Value="1"/>
                <Setter Property="Margin" Value="0,4"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Separator}">
                            <Border Background="{TemplateBinding Background}" Height="{TemplateBinding Height}" SnapsToDevicePixels="True"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>

        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="EpgColumn" Width="0"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="DrawerColumn" Width="380"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- 自定义标题栏 -->
            <RowDefinition Height="*"/>    <!-- 视频区 -->
            <RowDefinition Height="Auto"/> <!-- 底部控制栏 -->
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Border Grid.Row="0" Grid.ColumnSpan="3" Background="{DynamicResource TitleBarBrush}" Height="40" BorderBrush="{DynamicResource BorderBrushCommon}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: App Icon & Dropdown Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="10,0">
                    <Button x:Name="BtnAppTitle" Click="BtnAppTitle_Click" Style="{StaticResource TitleBtnStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/srcbox.png" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource App_Name}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Right: Window Buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- 1. Topmost (Pin) -->
                    <ToggleButton x:Name="BtnPin" Style="{StaticResource TopBtnStyle}" Click="BtnPin_Click" ToolTip="{DynamicResource Tooltip_PinTop}">
                        <Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1" Stretch="None" VerticalAlignment="Center" HorizontalAlignment="Center"
                              Data="M8,15 V11 M4,11 H12 M5,11 V5 H11 V11 M4,5 H12"/>
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border x:Name="bd" Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource ButtonPressedBackgroundBrush}"/>
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <!-- Pinned State (Yellow) -->
                                                <Path Stroke="{DynamicResource AccentBrush}" StrokeThickness="1" Stretch="None" VerticalAlignment="Center" HorizontalAlignment="Center"
                                                      Data="M8,15 V11 M4,11 H12 M5,11 V5 H11 V11 M4,5 H12"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource ButtonHoverBackgroundBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>

                    <!-- 2. Minimize -->
                    <Button x:Name="BtnMin" Style="{StaticResource TopBtnStyle}" Click="BtnMin_Click">
                        <Path Data="M4,12 H12" Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1" Stretch="None" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>

                    <!-- 3. Maximize/Restore -->
                    <Button x:Name="BtnMax" Style="{StaticResource TopBtnStyle}" Click="BtnMax_Click">
                         <!-- Auto-switching icon based on WindowState -->
                        <Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1" Stretch="None" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Data" Value="M4.5,4.5 H11.5 V11.5 H4.5 Z"/> <!-- Square (Maximize) -->
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=WindowState}" Value="Maximized">
                                            <Setter Property="Data" Value="M4.5,6.5 H9.5 V11.5 H4.5 Z M6.5,6.5 V4.5 H11.5 V9.5 H9.5"/> <!-- Double Square (Restore) -->
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Button>
                    
                    <!-- 4. Fullscreen (Yellow when Checked) -->
                    <ToggleButton x:Name="BtnWinFullscreen" Style="{StaticResource TopBtnStyle}" Click="CbFullscreen_Checked">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border x:Name="bd" Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource ButtonPressedBackgroundBrush}"/>
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <Path Data="M3.5,6.5 V3.5 H6.5 M9.5,3.5 H12.5 V6.5 M12.5,9.5 V12.5 H9.5 M6.5,12.5 H3.5 V9.5" 
                                                      Stroke="{DynamicResource AccentBrush}" StrokeThickness="1" Stretch="None" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                    <Trigger Property="IsChecked" Value="False">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <Path Data="M3.5,6.5 V3.5 H6.5 M9.5,3.5 H12.5 V6.5 M12.5,9.5 V12.5 H9.5 M6.5,12.5 H3.5 V9.5" 
                                                      Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1" Stretch="None" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource ButtonHoverBackgroundBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>

                    <!-- 5. Close -->
                    <Button x:Name="BtnClose" Click="BtnClose_Click" Background="Transparent">
                        <Button.Style>
                            <Style TargetType="ButtonBase" BasedOn="{StaticResource TopBtnStyle}">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource DangerButtonBackgroundBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Path Data="M4.5,4.5 L11.5,11.5 M11.5,4.5 L4.5,11.5" Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1" Stretch="None" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 左侧 EPG 抽屉 -->
        <Grid x:Name="EpgPanel" Grid.Row="1" Grid.Column="0" Background="{DynamicResource CardBackgroundBrush}" Visibility="Collapsed">
             <!-- ... EPG Content (Same as before) ... -->
             <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <DockPanel Grid.Row="0" Margin="12,16,12,8">
                <TextBlock Text="{DynamicResource EPG_Title}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="Bold" DockPanel.Dock="Left"/>
                <Button x:Name="BtnEpgCollapse" DockPanel.Dock="Right" Style="{StaticResource BarButton}" ToolTip="{DynamicResource EPG_Collapse}" Click="BtnEpgCollapse_Click">
                    <Path Data="M6,0 L0,4 L6,8" Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="2" Stretch="None" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>
                <TextBlock x:Name="LblEpgChannel" Text="" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14" Margin="12,2,0,0" TextTrimming="CharacterEllipsis" 
                           HorizontalAlignment="Center" TextAlignment="Center"/>
            </DockPanel>
            <Grid Grid.Row="1" Margin="12,0,12,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="BtnPrevDay" Grid.Column="0" Click="BtnPrevDay_Click" Style="{StaticResource BarButton}" Width="60" Background="{DynamicResource ChipButtonBackgroundBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource BorderBrushCommon}" BorderThickness="1" ToolTip="{DynamicResource EPG_PrevDay}">
                    <TextBlock Text="{DynamicResource EPG_PrevDay}" FontSize="12"/>
                </Button>
                <Border Grid.Column="1" Background="{StaticResource AccentBrush}" CornerRadius="4" Margin="12,0" HorizontalAlignment="Stretch">
                    <TextBlock x:Name="TxtCurrentDate" Text="{DynamicResource EPG_Today}" Foreground="Black" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14"/>
                </Border>
                <Button x:Name="BtnNextDay" Grid.Column="2" Click="BtnNextDay_Click" Style="{StaticResource BarButton}" Width="60" Background="{DynamicResource ChipButtonBackgroundBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource BorderBrushCommon}" BorderThickness="1" ToolTip="{DynamicResource EPG_NextDay}">
                    <TextBlock Text="{DynamicResource EPG_NextDay}" FontSize="12"/>
                </Button>
            </Grid>
            <ListBox x:Name="ListEpg" Grid.Row="2" Background="Transparent" BorderThickness="0" Margin="0,0,0,0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <EventSetter Event="PreviewMouseLeftButtonDown" Handler="ListEpg_PreviewMouseLeftButtonDown"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border Background="{TemplateBinding Background}" Padding="8,6" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource DividerBrush}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource ChipButtonHoverBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource ChipButtonPressedBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Start, StringFormat=HH:mm}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"/>
                                <TextBlock Text="{Binding End, StringFormat=HH:mm}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0">
                                <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Description}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" TextTrimming="CharacterEllipsis" Visibility="{Binding Description, Converter={StaticResource StringToVis}}"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="{Binding Status}" VerticalAlignment="Center" FontSize="12" HorizontalAlignment="Right">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                                <Setter Property="Text" Value="{DynamicResource EPG_Status_PlaybackWithIcon}"/>
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="直播">
                                                <Setter Property="Foreground" Value="{DynamicResource StatusLiveBrush}"/> <!-- Red -->
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="回放">
                                                <Setter Property="Foreground" Value="{DynamicResource StatusReplayBrush}"/> <!-- Green -->
                                                <Setter Property="Cursor" Value="Hand"/>
                                            </DataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Status}" Value="回放"/>
                                                    <Condition Binding="{Binding IsPlaying}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                            </MultiDataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="预约">
                                                <Setter Property="Foreground" Value="{DynamicResource StatusBookBrush}"/> <!-- Blue -->
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- 视频区域 -->
        <Grid Grid.Row="1" Grid.Column="1" Background="Black" PreviewMouseWheel="VideoArea_PreviewMouseWheel">
            <wfi:WindowsFormsHost x:Name="VideoHost" Background="Black" PreviewMouseWheel="VideoHost_PreviewMouseWheel">
                <wf:Panel x:Name="VideoPanel" BackColor="Black"/>
            </wfi:WindowsFormsHost>
            
            <!-- Placeholder (Visible when not playing) -->
            <StackPanel x:Name="PlaceholderPanel" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Visible" IsHitTestVisible="False">
                <Image Source="/srcbox.png" Width="64" Height="64" Margin="0,0,0,16" RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Text="{DynamicResource App_Name}" Foreground="#EEEEEE" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="{DynamicResource App_DescShort}" Foreground="#CCCCCC" FontSize="14" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Playback Status Indicator (Live/Catchup) -->
            <Border x:Name="PlaybackStatusIndicator" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="20,0,0,140" 
                    Background="{DynamicResource StatusIndicatorBackgroundBrush}" CornerRadius="4" Padding="8,4" Visibility="Collapsed" IsHitTestVisible="False">
                <TextBlock x:Name="TxtPlaybackStatus" Text="{DynamicResource EPG_Status_Live}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" FontWeight="Bold"/>
            </Border>
        </Grid>

        <!-- 右侧频道/分组抽屉 -->
        <Border Grid.Row="1" Grid.Column="2" Grid.RowSpan="2" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource BorderBrushCommon}" BorderThickness="1,0,0,0" x:Name="DrawerPanel">
             <!-- ... Drawer Content (Same as before) ... -->
             <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="12,16,12,8">
                    <TextBlock Text="{DynamicResource Drawer_Title}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="Bold" DockPanel.Dock="Left"/>
                    <Button x:Name="BtnDrawerCollapse" DockPanel.Dock="Right" Style="{StaticResource BarButton}" ToolTip="{DynamicResource Drawer_Collapse}" Click="BtnDrawerCollapse_Click" HorizontalAlignment="Right">
                        <Path Data="M0,0 L6,4 L0,8" Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="2" Stretch="None" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                </DockPanel>
                
                <!-- 抽屉顶部（标签式导航） -->
                <TabControl Grid.Row="1" Background="{DynamicResource CardBackgroundBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderThickness="0" x:Name="DrawerTabs">
                    <TabControl.Resources>
                        <Style x:Key="DarkTabItem" TargetType="{x:Type TabItem}">
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
                            <Setter Property="Padding" Value="16,10"/>
                            <Setter Property="Margin" Value="0,0,6,0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type TabItem}">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ChipButtonHoverBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ChipButtonHoverBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabControl.Resources>
                    <TabControl.ItemContainerStyle>
                        <StaticResource ResourceKey="DarkTabItem"/>
                    </TabControl.ItemContainerStyle>
                    <TabItem Header="{DynamicResource Tab_AllChannels}" x:Name="TabAll">
                        <Grid Background="Transparent">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- 搜索区 -->
                            <Grid Grid.Row="0" Margin="10,10,10,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtSearch" Grid.Column="0" Height="30" Background="{DynamicResource ChipButtonBackgroundBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderThickness="0" VerticalContentAlignment="Center" Padding="6,0" TextChanged="TxtSearch_TextChanged" />
                                <Button Grid.Column="1" Content="{DynamicResource Drawer_Clear}" Width="50" Height="30" Margin="8,0,0,0" Click="BtnClearSearch_Click" Style="{StaticResource BarButton}" Background="{DynamicResource ChipButtonBackgroundBrush}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </Grid>
                            <!-- 列表区 -->
                            <Grid Grid.Row="1" Margin="0,10,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="TxtCount" Grid.Row="0" Margin="10,0,10,5" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                                <ListBox x:Name="ListChannels" Grid.Row="1" Background="Transparent" BorderThickness="0" 
                                         ScrollViewer.CanContentScroll="True"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         VirtualizingPanel.IsVirtualizing="True"
                                         VirtualizingPanel.VirtualizationMode="Recycling"
                                         MouseEnter="ListChannels_MouseEnter"
                                         AlternationCount="999999">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="true">
                                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsSelected" Value="true">
                                                                <Setter TargetName="Bd" Property="Background" Value="Transparent"/>
                                                            </Trigger>
                                                            <Trigger Property="IsMouseOver" Value="true">
                                                                <Setter TargetName="Bd" Property="Background" Value="Transparent"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border x:Name="ItemBorder" Margin="6,4,6,4" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="6" PreviewMouseLeftButtonDown="OnPreviewMouseLeftButtonDown" BorderThickness="1" BorderBrush="{DynamicResource BorderBrushCommon}">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                                <Setter Property="Background" Value="{DynamicResource ChipButtonHoverBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource ChipButtonHoverBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid Margin="8,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="28"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="16"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="36"/>
                                                        <ColumnDefinition Width="80"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding GlobalIndex}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="12"/>
                                                    <Ellipse Grid.Column="2" Width="6" Height="6" Fill="#35C759" VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="4" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontSize="14" TextTrimming="CharacterEllipsis">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Playing}" Value="True">
                                                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                                            <Setter Property="FontWeight" Value="Bold"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding Group}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding CurrentProgramTitle}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" Visibility="{Binding CurrentProgramTitle, Converter={StaticResource StringToVis}}"/>
                                                    </StackPanel>
                                            <Button Grid.Column="5" Style="{StaticResource BarButton}" Click="ToggleFavorite_Click" ToolTip="{DynamicResource Favorite_Toggle}">
                                                        <TextBlock Text="{Binding Favorite, Converter={StaticResource BoolToStar}}" FontSize="16" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                    </Button>
                                                    <Border Grid.Column="6" Width="80" Height="40" Background="{DynamicResource ChipButtonBackgroundBrush}" CornerRadius="8" HorizontalAlignment="Right">
                                                        <Image helpers:ImageExtensions.RemoteUrl="{Binding Logo}" Stretch="Uniform" Width="80" Height="40"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Grid>
                    </TabItem>
                    <TabItem Header="{DynamicResource Tab_Groups}" x:Name="TabGroups">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="6,6,6,6" Background="Transparent">
                            <ItemsControl x:Name="ListGroups" >
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Expander IsExpanded="False" Margin="0,4,0,0" Background="{DynamicResource CardBackgroundBrush}" Foreground="{DynamicResource TextPrimaryBrush}">
                                            <Expander.Header>
                                                <DockPanel LastChildFill="True" Margin="6,4">
                                                    <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13"/>
                                                    <TextBlock Text="{Binding Count, StringFormat=(\{0\})}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" DockPanel.Dock="Right"/>
                                                </DockPanel>
                                            </Expander.Header>
                                            <ItemsControl ItemsSource="{Binding Items}" AlternationCount="999999">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="6,8,6,0" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="6" PreviewMouseLeftButtonDown="OnPreviewMouseLeftButtonDown">
                                                            <Grid Margin="8,8">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="28"/>
                                                                    <ColumnDefinition Width="8"/>
                                                                    <ColumnDefinition Width="16"/>
                                                                    <ColumnDefinition Width="8"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="36"/>
                                                                    <ColumnDefinition Width="80"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="{Binding DisplayIndex}"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="12"/>
                                                                <Ellipse Grid.Column="2" Width="6" Height="6" Fill="#35C759" VerticalAlignment="Center"/>
                                                                <StackPanel Grid.Column="4" VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding Name}" FontSize="14" TextTrimming="CharacterEllipsis">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Playing}" Value="True">
                                                                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                    <TextBlock Text="{Binding Group}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                                                    <TextBlock Text="{Binding CurrentProgramTitle}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" Visibility="{Binding CurrentProgramTitle, Converter={StaticResource StringToVis}}"/>
                                                                </StackPanel>
                                                                <Button Grid.Column="5" Style="{StaticResource BarButton}" Click="ToggleFavorite_Click" ToolTip="{DynamicResource Favorite_Toggle}">
                                                                    <TextBlock Text="{Binding Favorite, Converter={StaticResource BoolToStar}}" FontSize="16" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                                </Button>
                                                                <Border Grid.Column="6" Width="80" Height="40" Background="{DynamicResource ChipButtonBackgroundBrush}" CornerRadius="8" HorizontalAlignment="Right">
                                                                    <Image helpers:ImageExtensions.RemoteUrl="{Binding Logo}" Stretch="Uniform" Width="80" Height="40"/>
                                                                </Border>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Expander>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="{DynamicResource Tab_History}" x:Name="TabHistory">
                        <Grid Background="Transparent">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0" Margin="12,12,12,8">
                                <TextBlock Text="{DynamicResource History_Title}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" FontWeight="Bold" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                                    <Button x:Name="BtnHistoryDelete" Content="{DynamicResource History_DeleteSelected}" Click="BtnHistoryDelete_Click" Style="{StaticResource ActionChipButton}"/>
                                    <Button x:Name="BtnHistoryClear" Content="{DynamicResource History_ClearAll}" Click="BtnHistoryClear_Click" Style="{StaticResource ActionChipButton}" Margin="8,0,0,0"/>
                                </StackPanel>
                            </DockPanel>
                            <ListBox x:Name="ListHistory" Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="10,0,10,0" SelectionMode="Extended" MouseDoubleClick="ListHistory_MouseDoubleClick"
                                     ScrollViewer.CanContentScroll="True"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.VirtualizationMode="Recycling">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="ContextMenu">
                                            <Setter.Value>
                                                <ContextMenu>
                                                    <MenuItem Header="{DynamicResource History_Context_DeleteOne}" Command="ApplicationCommands.Delete" CommandParameter="{Binding}"/>
                                                </ContextMenu>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="6,8,6,0" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="6">
                                            <Grid Margin="8,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="28"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="16"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="80"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="12" Visibility="Collapsed"/>
                                                <Ellipse Grid.Column="2" Width="6" Height="6" Fill="#0A84FF" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="4" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Name}" FontSize="14" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                        <Border Style="{StaticResource TagChip}">
                                                            <TextBlock Text="{Binding PlayTypeLabel}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Group}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding SourceUrl}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                                <Border Grid.Column="6" Width="80" Height="40" Background="{DynamicResource ChipButtonBackgroundBrush}" CornerRadius="8" HorizontalAlignment="Right">
                                                    <Image helpers:ImageExtensions.RemoteUrl="{Binding Logo}" Stretch="Uniform" Width="80" Height="40"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </TabItem>
                    <TabItem Header="{DynamicResource Tab_Favorites}">
                        <ListBox x:Name="ListFavorites" Background="Transparent" BorderThickness="0" Margin="10,10,10,0">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="0"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="6,8,6,0" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="6" PreviewMouseLeftButtonDown="OnPreviewMouseLeftButtonDown">
                                        <Grid Margin="8,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="28"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="16"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="36"/>
                                                <ColumnDefinition Width="80"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding GlobalIndex}" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="12"/>
                                            <Ellipse Grid.Column="2" Width="6" Height="6" Fill="#35C759" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="4" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontSize="14" TextTrimming="CharacterEllipsis">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Playing}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Group}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding CurrentProgramTitle}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" Visibility="{Binding CurrentProgramTitle, Converter={StaticResource StringToVis}}"/>
                                            </StackPanel>
                                            <Button Grid.Column="5" Style="{StaticResource BarButton}" Click="ToggleFavorite_Click" ToolTip="{DynamicResource Favorite_Toggle}">
                                                <TextBlock Text="{Binding Favorite, Converter={StaticResource BoolToStar}}" FontSize="16" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            </Button>
                                            <Border Grid.Column="6" Width="80" Height="40" Background="{DynamicResource ChipButtonBackgroundBrush}" CornerRadius="8" HorizontalAlignment="Right">
                                                <Image helpers:ImageExtensions.RemoteUrl="{Binding Logo}" Stretch="Uniform" Width="80" Height="40"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>

        <!-- 底部控制栏 -->
        <Border x:Name="BottomBar" Grid.Row="2" Grid.Column="1" Background="{DynamicResource TitleBarBrush}" Height="64" BorderBrush="{DynamicResource BorderBrushCommon}" BorderThickness="0,1,0,0" PreviewMouseWheel="BottomBar_PreviewMouseWheel">
            <Grid Margin="12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- 进度条 -->
                    <RowDefinition Height="*"/>    <!-- 按钮 -->
                </Grid.RowDefinitions>

                <!-- 进度条行 -->
                <Grid Grid.Row="0" Margin="0,0,0,0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <Slider Grid.Column="0" x:Name="SliderSeek" Height="20" Style="{StaticResource UnifiedThickSlider}" 
                            Minimum="0" Maximum="100" 
                            ValueChanged="SliderSeek_ValueChanged" 
                            PreviewMouseDown="SliderSeek_PreviewMouseDown"
                            PreviewMouseUp="SliderSeek_PreviewMouseUp"
                            PreviewMouseMove="SliderSeek_MouseMove"
                            MouseLeave="SliderSeek_MouseLeave"/>
                    <Grid Grid.Column="1" Margin="12,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="BtnMute" Grid.Column="0" Style="{StaticResource BarButton}" ToolTip="{DynamicResource Overlay_Mute}" Click="BtnMute_Click" Width="32" Height="20" Margin="0,0,6,0">
                            <ui:SymbolIcon x:Name="IconMute" Symbol="Volume" />
                        </Button>
                        <Slider Grid.Column="1" x:Name="SliderVolume" Minimum="0" Maximum="100" 
                                ValueChanged="SliderVolume_ValueChanged" Style="{StaticResource UnifiedThickSlider}" VerticalAlignment="Center"/>
                    </Grid>
                </Grid>

                <!-- 按钮行 -->
                <Grid Grid.Row="1" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/> <!-- 左 -->
                        <ColumnDefinition Width="*"/>    <!-- 中 -->
                        <ColumnDefinition Width="Auto"/> <!-- 右 -->
                    </Grid.ColumnDefinitions>

                    <!-- 左侧：播放控制 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Border x:Name="BottomStatusIndicator" Height="32" VerticalAlignment="Center" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="4" Padding="10,0" Margin="0,0,8,0">
                            <TextBlock x:Name="TxtBottomPlaybackStatus" Text="{DynamicResource EPG_Status_Live}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                        </Border>
                        <Button x:Name="BtnPlayPause" Style="{StaticResource BarButton}" Click="BtnPlayPause_Click">
                            <ui:SymbolIcon x:Name="IconPlayPause" Symbol="Play"/>
                        </Button>
                        <Button x:Name="BtnStop" Style="{StaticResource BarButton}" Click="BtnStop_Click">
                            <ui:SymbolIcon Symbol="Stop"/>
                        </Button>
                        <Button x:Name="BtnRew" Style="{StaticResource BarButton}" Click="BtnRew_Click">
                            <ui:SymbolIcon Symbol="Previous"/>
                        </Button>
                        <Button x:Name="BtnFwd" Style="{StaticResource BarButton}" Click="BtnFwd_Click">
                            <ui:SymbolIcon Symbol="Next"/>
                        </Button>
                        
                        <!-- 时间信息 -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                            <TextBlock x:Name="LblElapsed" Text="00:00" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                            <TextBlock Text=" / " Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                            <TextBlock x:Name="LblDuration" Text="00:00" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                            <WrapPanel x:Name="TagPanel" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 右侧：工具 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <!-- FCC/UDP removed from here -->
                        <Button x:Name="BtnSources" Style="{StaticResource BarButton}" Click="BtnSources_Click" ToolTip="{DynamicResource Overlay_SwitchSource}">
                            <ui:SymbolIcon Symbol="Shuffle"/>
                        </Button>
                        <Button x:Name="BtnRatio" Style="{StaticResource BarButton}" Click="BtnRatio_Click" ToolTip="{DynamicResource Overlay_AspectRatio}">
                            <ui:SymbolIcon Symbol="Crop"/>
                        </Button>
                        <ToggleButton x:Name="CbTimeshift" Style="{StaticResource BarToggle}" Click="CbTimeshift_Click" ToolTip="{DynamicResource Overlay_Timeshift}">
                            <ui:SymbolIcon Symbol="Clock"/>
                        </ToggleButton>

                        <ToggleButton x:Name="CbEpg" Style="{StaticResource BarToggle}" Click="CbEpg_Click" ToolTip="{DynamicResource Overlay_EPG}">
                            <ui:SymbolIcon Symbol="Calendar"/>
                        </ToggleButton>
                        <ToggleButton x:Name="CbDrawer" Style="{StaticResource BarToggle}" Click="CbDrawer_Click" ToolTip="{DynamicResource Overlay_ToggleDrawer}">
                            <ui:SymbolIcon Symbol="List"/>
                        </ToggleButton>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
